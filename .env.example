# PromptShrink Environment Variables
# Copy this file to .env.local and fill in your values

# Anthropic API Key (optional - users can provide their own in settings)
# ANTHROPIC_API_KEY=sk-ant-api03-...

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: server-side key for shared demo usage
# PS_DEMO_API_KEY=sk-ant-api03-...
